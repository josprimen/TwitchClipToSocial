# Variables de entorno para DESARROLLO con Docker
# Copia este archivo a .env cuando uses docker-compose.dev.yml

# Laravel - DESARROLLO
APP_NAME=TwitchClips
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Base de datos externa (CONFIGURA ESTOS VALORES)
DB_CONNECTION=mysql
DB_HOST=192.168.1.100
DB_PORT=3306
DB_DATABASE=twitch
DB_USERNAME=tu_usuario
DB_PASSWORD=tu_contraseña

# Cache y sesiones (usando archivos)
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Chromium y Node (rutas dentro del contenedor)
NODE_BINARY_PATH=/usr/bin/node
NPM_BINARY_PATH=/usr/bin/npm
CHROMIUM_PATH=/usr/bin/chromium

# Google API (CONFIGURA ESTOS VALORES)
GOOGLE_KEY=
GOOGLE_ID=
GOOGLE_SECRET=
GOOGLE_FOLDER_ID=

# YouTube API (CONFIGURA ESTOS VALORES)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Instagram API (opcional)
INSTAGRAM_ID=
API_GRAPH_ACCESS_TOKEN=

# UID y GID para permisos correctos (Linux/Mac)
# En Linux: usa tu UID/GID actual (ejecuta: id -u / id -g)
# En Windows: deja comentado
# UID=1000
# GID=1000
